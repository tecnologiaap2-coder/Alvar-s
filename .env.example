# ─── CONFIGURAÇÕES DO SISTEMA ───────────────────────────────────────────────
# Copie este arquivo para .env e preencha as variáveis

# Emails do escritório (já definidos no src/App.jsx — altere lá se necessário)
VITE_EMAIL_FELIPE=felipe@arosopontinadvogados.com.br
VITE_EMAIL_ESCRITORIO=escritorio@arosopontinadvogados.com.br

# URLs dos servidores MCP Google (não alterar)
VITE_MCP_GMAIL=https://gmailmcp.googleapis.com/mcp/v1
VITE_MCP_CALENDAR=https://calendarmcp.googleapis.com/mcp/v1

# Chave da API Anthropic (necessária para funcionar a IA e as integrações)
# Obtenha em: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=sk-ant-...
